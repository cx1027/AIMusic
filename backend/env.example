# Backend env example
#
# Copy to `backend/.env` (same working directory where you run uvicorn),
# or export these variables in your shell.

# --- Core ---
ENV=dev
API_PREFIX=/api
CORS_ORIGINS=http://localhost:5173
JWT_SECRET=change_me

# --- Database / Redis ---
DATABASE_URL=postgresql+psycopg://aimusic:aimusic@localhost:5432/aimusic
REDIS_URL=redis://localhost:6379/0

# --- Music generation backend selector ---
# celery | runpod
MUSIC_GENERATION_BACKEND=runpod

# --- RunPod Serverless ---
# Find these in RunPod console:
# - API key: Settings -> API Keys
# - Endpoint ID: Serverless -> your endpoint -> endpoint id
RUNPOD_API_KEY=rp_live_xxx
RUNPOD_ENDPOINT_ID=xxxxxxxxxxxxxxxx
# Optional (defaults shown):
RUNPOD_API_BASE_URL=https://api.runpod.ai/v2
RUNPOD_REQUEST_TIMEOUT_SECONDS=30

# App
APP_NAME="AI Music"
ENV="dev"
API_PREFIX="/api"
CORS_ORIGINS="http://localhost:5173"

# Security
JWT_SECRET="change_me"
JWT_ALG="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Database
DATABASE_URL="postgresql+psycopg://aimusic:aimusic@localhost:5432/aimusic"

# Redis
REDIS_URL="redis://localhost:6379/0"

# Storage (local by default)
STORAGE_BACKEND="local"  # local | s3
LOCAL_STORAGE_DIR=".data"

# Optional S3/R2
S3_ENDPOINT_URL=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_REGION="auto"
S3_BUCKET=""

# ACE-Step 1.5 (local inference)
ACE_STEP_MODEL_DIR="models/ace-step-1.5"
ACE_STEP_DEVICE="mps"
# ACE-Step settings
ACE_STEP_ENTRYPOINT=ace_step.inference:generate
ACE_STEP_MODEL_DIR=/absolute/path/to/ACE-Step-1.5/checkpoints
ACE_STEP_DEVICE=mps  # or cuda / cpu

# FLUX.1 Schnell image generation
# Provider: huggingface | runpod (default: huggingface)
FLUXSCHNELL=huggingface  # Set to RUNPOD to use RunPod serverless endpoint
FLUX_MODEL_DIR="models/flux_schnell"
FLUX_DEVICE="mps"  # mps (Mac), cuda, cpu
# Hugging Face token for accessing gated models (FLUX.1-schnell)
# Accept model license at: https://huggingface.co/black-forest-labs/FLUX.1-schnell
# Get token from: https://huggingface.co/settings/tokens
HUGGINGFACE_HUB_TOKEN=""  # Use HUGGINGFACE_HUB_TOKEN (recommended) or HUGGINGFACE_TOKEN
FLUX_RUNPOD_ENDPOINT_ID=""  # RunPod endpoint ID for FLUX.1 Schnell (e.g., vgsdku5vpadklr)
RUNPOD_API_KEY=""  # RunPod API key (required if using RunPod provider)


